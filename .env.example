# Database
WISDOM_DATABASE_URL=postgresql+asyncpg://postgres:postgres@localhost:5432/wisdom_spark

# Redis (optional, for caching)
WISDOM_REDIS_URL=redis://localhost:6379/0

# Embeddings (OpenAI-compatible API)
WISDOM_EMBEDDING_API_KEY=sk-your-key-here
WISDOM_EMBEDDING_API_BASE=https://api.openai.com/v1
WISDOM_EMBEDDING_MODEL=text-embedding-3-small

# API
WISDOM_DEBUG=true

# ---- Autonomous Crawler ----
CRAWLER_DATABASE_URL=postgresql+asyncpg://postgres:postgres@localhost:5432/wisdom_spark

# LLM for evaluating discovered wisdom (Anthropic or OpenAI)
CRAWLER_LLM_API_KEY=sk-ant-your-key-here
CRAWLER_LLM_API_BASE=https://api.anthropic.com
CRAWLER_LLM_MODEL=claude-sonnet-4-20250514
CRAWLER_LLM_PROVIDER=anthropic

# Embedding for deduplication
CRAWLER_EMBEDDING_API_KEY=sk-your-key-here
CRAWLER_EMBEDDING_API_BASE=https://api.openai.com/v1

# Crawler behavior
CRAWLER_CRAWL_INTERVAL_MINUTES=120
CRAWLER_MAX_CANDIDATES_PER_RUN=30
CRAWLER_MIN_FLOURISHING_SCORE=0.6
CRAWLER_MIN_DIGNITY_SCORE=0.7
CRAWLER_MAX_DIVISIVENESS=0
CRAWLER_DEDUP_SIMILARITY_THRESHOLD=0.92
